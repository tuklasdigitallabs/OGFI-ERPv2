# OGFI ERP production environment - placeholder values only
COMPOSE_PROJECT_NAME=ogfi-erp-production
APP_ENV=production
NODE_VERSION=22
APP_URL=https://erp.example.com
APP_DEFAULT_TIMEZONE=Asia/Manila
LOG_LEVEL=info

# PostgreSQL - application runtime credential only. Never add DIRECT_DATABASE_URL
# or an owner/migrator credential to this application environment file.
DATABASE_URL=postgresql://ogfi_prod_runtime:replace-me@prod-db.internal:5432/ogfi_erp_production?schema=public

# Redis - future approved worker/queue scope only
# REDIS_URL=

# Auth and encryption - unique production secrets
AUTH_MODE=local
AUTH_TRUSTED_PROXY_MODE=caddy_single_hop
AUTH_SECRET=replace-with-production-secret
AUTH_THROTTLE_HMAC_KEY=replace-with-distinct-production-throttle-hmac-key
AUTH_THROTTLE_KEY_VERSION=1
# Configure these only during a reviewed, database-fenced rotation.
# AUTH_THROTTLE_PREVIOUS_HMAC_KEY=
# AUTH_THROTTLE_PREVIOUS_KEY_VERSION=
AUTH_THROTTLE_WINDOW_MINUTES=15
AUTH_THROTTLE_RETENTION_DAYS=30
AUTH_THROTTLE_IDENTIFIER_SHARDS=64
AUTH_THROTTLE_SOURCE_SHARDS=64
# Required after production-like load calibration; intentionally blank until approved.
AUTH_ARGON2_MAX_CONCURRENCY=
# Keep false until the 18-type backfill/inbox matrix and cutover rehearsal pass.
APPROVAL_ROUTING_V1_ENABLED=false
AUTH_HEALTH_METRICS_TOKEN=
CADDY_METRICS_URL=http://caddy:2020/metrics
AUTH_RUNTIME_METRICS_URL=http://127.0.0.1:2021/api/internal/authentication-metrics
AUTH_THROTTLE_HEALTH_GRACE_MINUTES=10
# Required after production-like load calibration; blanks fail health startup closed.
AUTH_THROTTLE_HEALTH_DENIED_THRESHOLD=
AUTH_THROTTLE_HEALTH_PRESSURE_PERMILLE=
AUTH_THROTTLE_HEALTH_ARGON2_REJECTED_THRESHOLD=
AUTH_THROTTLE_HEALTH_ARGON2_DURATION_MS=
AUTH_THROTTLE_HEALTH_CADDY_REJECTED_THRESHOLD=
APP_ENCRYPTION_KEY=replace-with-production-32-byte-base64-key
APP_ENCRYPTION_KEY_VERSION=1
# APP_ENCRYPTION_PREVIOUS_KEY=replace-only-during-reviewed-key-rotation
# APP_ENCRYPTION_PREVIOUS_KEY_VERSION=0
AUTH_SESSION_IDLE_MINUTES=30
AUTH_SESSION_ABSOLUTE_HOURS=12
AUTH_MFA_STEP_UP_MINUTES=15
AUTH_MFA_CHALLENGE_MINUTES=10
AUTH_MFA_CHALLENGE_LIMIT=5
# One-time first administrator bootstrap only; remove after successful ceremony.
# AUTH_BOOTSTRAP_TENANT_CODE=
# AUTH_BOOTSTRAP_USER_EMAIL=
# AUTH_BOOTSTRAP_AUTHORIZATION_REFERENCE=
# AUTH_BOOTSTRAP_OUTPUT_FILE=/run/secrets/ogfi-initial-activation.txt
# AUTH_ENCRYPTION_ROTATION_BATCH_SIZE=100

# Demo placeholders must be replaced with approved production support accounts or left unused.
DEMO_USER_EMAIL=
DEMO_APPROVER_EMAIL=
DEMO_ADMIN_EMAIL=
DEMO_COMPANY_NAME=Configured Company
DEMO_BRAND_NAME=Configured Brand
DEMO_LOCATION_NAME=Configured Location

# Controlled evidence — private broker and ClamAV on the Hostinger VPS.
# The broker shared secret and evidence encryption key are separate Docker secrets.
EVIDENCE_STORAGE_PROVIDER=hostinger-local
EVIDENCE_BROKER_URL=http://evidence-broker:3010
EVIDENCE_BROKER_SHARED_SECRET_FILE=/run/secrets/evidence_broker_shared_secret
EVIDENCE_SCAN_RECONCILIATION_ENABLED=true
EVIDENCE_SCAN_RECONCILIATION_BATCH_SIZE=50
EVIDENCE_SCAN_RECONCILIATION_INTERVAL_SECONDS=60
EVIDENCE_SCAN_RECONCILIATION_LEASE_SECONDS=45
EVIDENCE_SCAN_RECONCILIATION_MAX_ATTEMPTS=10
EVIDENCE_SCAN_PENDING_TIMEOUT_MINUTES=60
EVIDENCE_SCAN_SIGNATURE_MAX_AGE_HOURS=24
EVIDENCE_UPLOAD_INTENT_TTL_SECONDS=300
EVIDENCE_UPLOAD_INTENT_ABSOLUTE_TTL_SECONDS=900
EVIDENCE_UPLOAD_LEASE_SECONDS=180
EVIDENCE_MAX_ACTIVE_UPLOAD_INTENTS_PER_USER=20
EVIDENCE_MAX_ACTIVE_UPLOAD_INTENTS_PER_COMPANY=500
EVIDENCE_MAX_UPLOAD_INTENTS_PER_USER_HOUR=100
EVIDENCE_MAX_UPLOAD_INTENTS_PER_COMPANY_HOUR=2000
EVIDENCE_MAX_UPLOAD_BYTES=26214400
EVIDENCE_DEFAULT_COMPANY_QUOTA_BYTES=
EVIDENCE_READINESS_LIVE_CHECK=true
EVIDENCE_BROKER_REQUEST_TIMEOUT_MS=10000
EVIDENCE_BROKER_MINIMUM_FREE_BYTES=
EVIDENCE_BROKER_MINIMUM_FREE_PERCENT=
EVIDENCE_BROKER_MINIMUM_FREE_INODE_PERCENT=
EVIDENCE_BROKER_CLAMD_TIMEOUT_MS=60000
EVIDENCE_BROKER_MAXIMUM_SIGNATURE_AGE_SECONDS=86400

# Host-only deployment values consumed by the production Compose overlay.
EVIDENCE_HOST_STORAGE_ROOT=/srv/ogfi/evidence/production
OGFI_PRODUCTION_ENV_FILE=/srv/ogfi/config/production.env
# The root-owned database migration contract is stored separately at
# /etc/ogfi/database/role-contract.env; see infra/systemd/database/README.md.
OGFI_WEB_IMAGE=replace-with-reviewed-ogfi-image-digest
CLAMAV_IMAGE=replace-with-reviewed-clamav-image-digest
CADDY_IMAGE=replace-with-reviewed-ogfi-caddy-image-at-sha256
CADDY_ROLLBACK_IMAGE=replace-with-previous-reviewed-ogfi-caddy-image-at-sha256
EVIDENCE_BROKER_SHARED_SECRET_FILE_HOST=/srv/ogfi/secrets/evidence-broker-shared-secret
EVIDENCE_BROKER_KEYS_FILE_HOST=/srv/ogfi/secrets/evidence-broker-keyring.json
EVIDENCE_BROKER_RUNTIME_UID_GID=
CLAMAV_RUNTIME_UID_GID=
CLAMAV_SIGNATURES_CONTAINER_PATH=
CLAMAV_SIGNATURE_VOLUME_NAME=
CLAMAV_HEALTHCHECK_CMD=
WEB_MEMORY_LIMIT=
WEB_CPU_LIMIT=
WEB_PIDS_LIMIT=
EVIDENCE_BROKER_MEMORY_LIMIT=
EVIDENCE_BROKER_CPU_LIMIT=
EVIDENCE_BROKER_PIDS_LIMIT=
EVIDENCE_BROKER_TMPFS_SIZE=
CLAMAV_MEMORY_LIMIT=
CLAMAV_CPU_LIMIT=
CLAMAV_PIDS_LIMIT=
CLAMAV_TMPFS_SIZE=
CLAMAV_RUN_TMPFS_SIZE=
CADDY_RUNTIME_UID_GID=
CADDY_TMPFS_SIZE=
CADDY_MEMORY_LIMIT=
CADDY_CPU_LIMIT=
CADDY_PIDS_LIMIT=
CONTAINER_LOG_MAX_SIZE=
CONTAINER_LOG_MAX_FILES=

# Email - approved production sender only
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=erp@example.com
SMTP_SECURITY=starttls

# Observability - required before production GO
ERROR_MONITORING_DSN=replace-with-production-error-monitoring-dsn

# Reverse proxy / deployment. Rate and inflight limits stay blank until staged
# Hostinger load and shared-NAT evidence is reviewed and approved.
WEB_PORT=3000
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
OGFI_SITE_ADDRESS=erp.example.com
MAX_REQUEST_BODY_SIZE=27MiB
CADDY_READ_HEADER_TIMEOUT=10s
CADDY_READ_BODY_TIMEOUT=5m
CADDY_WRITE_TIMEOUT=5m
CADDY_IDLE_TIMEOUT=2m
CADDY_UPSTREAM_DIAL_TIMEOUT=5s
CADDY_UPSTREAM_RESPONSE_HEADER_TIMEOUT=60s
CADDY_AUTH_RESPONSE_HEADER_TIMEOUT=30s
CADDY_AUTH_RATE_WINDOW=
CADDY_SIGN_IN_GLOBAL_EVENTS=
CADDY_SIGN_IN_SOURCE_EVENTS=
CADDY_ACTIVATE_GLOBAL_EVENTS=
CADDY_ACTIVATE_SOURCE_EVENTS=
CADDY_MFA_GLOBAL_EVENTS=
CADDY_MFA_SOURCE_EVENTS=
CADDY_PASSWORD_COARSE_INFLIGHT=
CADDY_MFA_COARSE_INFLIGHT=

# Backup / restore evidence helpers
BACKUP_DIR=backups/production
# BACKUP_FILE=backups/production/ogfi-erp-production-example.dump
# RESTORE_DATABASE_URL=postgresql://restore-user:replace-me@restore-db.internal:5432/ogfi_erp_production_restore?schema=public
ALLOW_RESTORE_TO_PRODUCTION=no
