generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum LocationType {
  BRANCH
  WAREHOUSE
  COMMISSARY
  CENTRAL_KITCHEN
  HEAD_OFFICE
  PROJECT_SITE
  TEMPORARY_SITE
}

enum ScopeType {
  COMPANY
  BRAND
  LOCATION
  DEPARTMENT
  PROJECT
}

enum AccessLevel {
  VIEW
  OPERATE
  APPROVE
  MANAGE
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
}

enum ApprovalStepStatus {
  WAITING
  PENDING
  APPROVED
  REJECTED
  RETURNED
  SKIPPED
}

enum InventoryMovementType {
  RECEIPT_IN
  TRANSFER_OUT
  TRANSFER_IN
  WASTAGE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  OPENING_BALANCE_IN
  COUNT_VARIANCE_IN
  COUNT_VARIANCE_OUT
  REVERSAL
}

enum ProjectTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectMemberRole {
  SPONSOR
  MANAGER
  CONTRIBUTOR
  VIEWER
  ADMINISTRATOR
}

enum ProjectTaskStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  WAITING_FOR_APPROVAL
  BLOCKED
  FOR_REVIEW
  COMPLETED
  CANCELLED
}

enum ProjectTaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ProjectBlockerStatus {
  OPEN
  RESOLVED
  ACCEPTED
  CANCELLED
}

enum ProjectBlockerSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectRiskStatus {
  OPEN
  MITIGATING
  MITIGATED
  ACCEPTED
  REALIZED
  CLOSED
  CANCELLED
}

enum ProjectRiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectCalendarDateKind {
  DATE_ONLY
  SCHEDULED_DATETIME
}

enum ProjectMilestoneStatus {
  PLANNED
  ACHIEVED
  CANCELLED
}

model Tenant {
  id                            String                         @id @default(uuid()) @db.Uuid
  name                          String
  status                        RecordStatus                   @default(ACTIVE)
  defaultTimezone               String                         @default("Asia/Manila")
  themeConfig                   Json?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  companies                     Company[]
  brands                        Brand[]
  locations                     Location[]
  departments                   Department[]
  costCenters                   CostCenter[]
  users                         User[]
  roles                         Role[]
  permissions                   Permission[]
  suppliers                     Supplier[]
  supplierItemLinks             SupplierItemLink[]
  supplierPriceHistory          SupplierPriceHistory[]
  itemCategories                ItemCategory[]
  uoms                          Uom[]
  items                         Item[]
  approvalRules                 ApprovalRule[]
  approvalInstances             ApprovalInstance[]
  purchaseRequests              PurchaseRequest[]
  purchaseRequestComments       PurchaseRequestComment[]
  quotationRequests             QuotationRequest[]
  supplierQuotations            SupplierQuotation[]
  quotationRecommendations      QuotationRecommendation[]
  purchaseOrders                PurchaseOrder[]
  purchaseOrderLines            PurchaseOrderLine[]
  purchaseOrderAmendments       PurchaseOrderAmendment[]
  purchaseOrderBalanceClosures  PurchaseOrderBalanceClosure[]
  inventoryLocations            InventoryLocation[]
  inventoryMovements            InventoryMovement[]
  inventoryBalances             InventoryBalance[]
  goodsReceipts                 GoodsReceipt[]
  goodsReceiptLines             GoodsReceiptLine[]
  inventoryTransfers            InventoryTransfer[]
  inventoryTransferLines        InventoryTransferLine[]
  inventoryTransferReceipts     InventoryTransferReceipt[]
  inventoryTransferReceiptLines InventoryTransferReceiptLine[]
  notifications                 Notification[]
  auditEvents                   AuditEvent[]
  attachments                   Attachment[]
  stockCountSessions            StockCountSession[]
  stockCountLines               StockCountLine[]
  wastageReports                WastageReport[]
  wastageLines                  WastageLine[]
  wastagePolicies               WastagePolicy[]
  operationalReasonCodes        OperationalReasonCode[]
  stockAdjustments              StockAdjustment[]
  stockAdjustmentLines          StockAdjustmentLine[]
  projectTemplates              ProjectTemplate[]
  projects                      Project[]
  projectMembers                ProjectMember[]
  projectActivityEvents         ProjectActivityEvent[]
  projectTasks                  ProjectTask[]
  projectTaskAssignees          ProjectTaskAssignee[]
  projectTaskChecklistItems     ProjectTaskChecklistItem[]
  projectComments               ProjectComment[]
  projectBlockers               ProjectBlocker[]
  projectRisks                  ProjectRisk[]
  projectMilestones             ProjectMilestone[]
  projectRecordLinks            ProjectRecordLink[]
  projectAttachments            ProjectAttachment[]
}

model Company {
  id                            String                         @id @default(uuid()) @db.Uuid
  tenantId                      String                         @db.Uuid
  code                          String
  legalName                     String
  tradingName                   String?
  taxIdentifier                 String?
  currencyCode                  String
  timezone                      String                         @default("Asia/Manila")
  status                        RecordStatus                   @default(ACTIVE)
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  tenant                        Tenant                         @relation(fields: [tenantId], references: [id])
  brands                        Brand[]
  locations                     Location[]
  departments                   Department[]
  costCenters                   CostCenter[]
  suppliers                     Supplier[]
  supplierItemLinks             SupplierItemLink[]
  supplierPriceHistory          SupplierPriceHistory[]
  itemCategories                ItemCategory[]
  uoms                          Uom[]
  items                         Item[]
  approvalRules                 ApprovalRule[]
  approvalInstances             ApprovalInstance[]
  purchaseRequests              PurchaseRequest[]
  purchaseRequestComments       PurchaseRequestComment[]
  quotationRequests             QuotationRequest[]
  supplierQuotations            SupplierQuotation[]
  quotationRecommendations      QuotationRecommendation[]
  purchaseOrders                PurchaseOrder[]
  purchaseOrderLines            PurchaseOrderLine[]
  purchaseOrderAmendments       PurchaseOrderAmendment[]
  purchaseOrderBalanceClosures  PurchaseOrderBalanceClosure[]
  inventoryLocations            InventoryLocation[]
  inventoryMovements            InventoryMovement[]
  inventoryBalances             InventoryBalance[]
  goodsReceipts                 GoodsReceipt[]
  goodsReceiptLines             GoodsReceiptLine[]
  inventoryTransfers            InventoryTransfer[]
  inventoryTransferLines        InventoryTransferLine[]
  inventoryTransferReceipts     InventoryTransferReceipt[]
  inventoryTransferReceiptLines InventoryTransferReceiptLine[]
  notifications                 Notification[]
  auditEvents                   AuditEvent[]
  stockCountSessions            StockCountSession[]
  stockCountLines               StockCountLine[]
  wastageReports                WastageReport[]
  wastageLines                  WastageLine[]
  wastagePolicies               WastagePolicy[]
  operationalReasonCodes        OperationalReasonCode[]
  stockAdjustments              StockAdjustment[]
  stockAdjustmentLines          StockAdjustmentLine[]
  projectTemplates              ProjectTemplate[]
  projects                      Project[]
  projectMembers                ProjectMember[]
  projectActivityEvents         ProjectActivityEvent[]
  projectTasks                  ProjectTask[]
  projectTaskAssignees          ProjectTaskAssignee[]
  projectTaskChecklistItems     ProjectTaskChecklistItem[]
  projectComments               ProjectComment[]
  projectBlockers               ProjectBlocker[]
  projectRisks                  ProjectRisk[]
  projectMilestones             ProjectMilestone[]
  projectRecordLinks            ProjectRecordLink[]
  projectAttachments            ProjectAttachment[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model Brand {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  companyId        String            @db.Uuid
  name             String
  code             String
  status           RecordStatus      @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  locations        Location[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  projects         Project[]

  @@unique([companyId, code])
  @@unique([id, tenantId, companyId])
  @@index([tenantId, companyId, status])
}

model Location {
  id                            String              @id @default(uuid()) @db.Uuid
  tenantId                      String              @db.Uuid
  companyId                     String              @db.Uuid
  brandId                       String?             @db.Uuid
  locationType                  LocationType
  code                          String
  name                          String
  address                       String?
  timezone                      String              @default("Asia/Manila")
  status                        RecordStatus        @default(ACTIVE)
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt
  tenant                        Tenant              @relation(fields: [tenantId], references: [id])
  company                       Company             @relation(fields: [companyId], references: [id])
  brand                         Brand?              @relation(fields: [brandId], references: [id])
  purchaseRequests              PurchaseRequest[]
  purchaseOrders                PurchaseOrder[]     @relation("PurchaseOrderDeliveryLocation")
  inventoryLocations            InventoryLocation[]
  goodsReceipts                 GoodsReceipt[]      @relation("GoodsReceiptReceivingLocation")
  sourceInventoryTransfers      InventoryTransfer[] @relation("InventoryTransferSourceLocation")
  destinationInventoryTransfers InventoryTransfer[] @relation("InventoryTransferDestinationLocation")
  notifications                 Notification[]
  projects                      Project[]

  @@unique([companyId, code])
  @@unique([id, tenantId, companyId])
  @@index([tenantId, companyId, status])
}

model Department {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  companyId        String            @db.Uuid
  name             String
  code             String
  status           RecordStatus      @default(ACTIVE)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  costCenters      CostCenter[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  projects         Project[]

  @@unique([companyId, code])
  @@unique([id, tenantId, companyId])
}

model CostCenter {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  companyId        String            @db.Uuid
  departmentId     String?           @db.Uuid
  code             String
  name             String
  status           RecordStatus      @default(ACTIVE)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  department       Department?       @relation(fields: [departmentId], references: [id])
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  projects         Project[]

  @@unique([companyId, code])
  @@unique([id, tenantId, companyId])
}

model User {
  id                                String                        @id @default(uuid()) @db.Uuid
  tenantId                          String                        @db.Uuid
  email                             String
  displayName                       String
  status                            RecordStatus                  @default(ACTIVE)
  lastLoginAt                       DateTime?
  createdAt                         DateTime                      @default(now())
  updatedAt                         DateTime                      @updatedAt
  tenant                            Tenant                        @relation(fields: [tenantId], references: [id])
  roleAssignments                   UserRoleAssignment[]
  scopeAssignments                  UserScopeAssignment[]
  requestedPurchaseRequests         PurchaseRequest[]             @relation("PurchaseRequestRequester")
  purchaseRequestComments           PurchaseRequestComment[]
  createdQuotationRequests          QuotationRequest[]
  preparedQuoteRecommendations      QuotationRecommendation[]
  createdPurchaseOrders             PurchaseOrder[]
  requestedPurchaseOrderAmendments  PurchaseOrderAmendment[]    @relation("PurchaseOrderAmendmentRequester")
  approvedPurchaseOrderAmendments   PurchaseOrderAmendment[]    @relation("PurchaseOrderAmendmentApprover")
  requestedPurchaseOrderClosures    PurchaseOrderBalanceClosure[] @relation("PurchaseOrderBalanceClosureRequester")
  approvedPurchaseOrderClosures     PurchaseOrderBalanceClosure[] @relation("PurchaseOrderBalanceClosureApprover")
  receivedGoodsReceipts             GoodsReceipt[]                @relation("GoodsReceiptReceiver")
  reversedGoodsReceipts             GoodsReceipt[]                @relation("GoodsReceiptReverser")
  requestedInventoryTransfers       InventoryTransfer[]           @relation("InventoryTransferRequester")
  dispatchedInventoryTransfers      InventoryTransfer[]           @relation("InventoryTransferDispatcher")
  receivedInventoryTransfers        InventoryTransfer[]           @relation("InventoryTransferReceiver")
  receivedInventoryTransferReceipts InventoryTransferReceipt[]    @relation("InventoryTransferReceiptReceiver")
  reversedInventoryTransferReceipts InventoryTransferReceipt[]    @relation("InventoryTransferReceiptReverser")
  createdStockCountSessions         StockCountSession[]           @relation("StockCountCreator")
  assignedStockCountSessions        StockCountSession[]           @relation("StockCountAssignee")
  reviewedStockCountSessions        StockCountSession[]           @relation("StockCountReviewer")
  countedStockCountLines            StockCountLine[]              @relation("StockCountLineCounter")
  reportedWastageReports            WastageReport[]               @relation("WastageReportReporter")
  reviewedWastageReports            WastageReport[]               @relation("WastageReportReviewer")
  postedWastageReports              WastageReport[]               @relation("WastageReportPoster")
  reversedWastageReports            WastageReport[]               @relation("WastageReportReverser")
  requestedStockAdjustments         StockAdjustment[]             @relation("StockAdjustmentRequester")
  cancelledStockAdjustments         StockAdjustment[]             @relation("StockAdjustmentCanceller")
  postedStockAdjustments            StockAdjustment[]             @relation("StockAdjustmentPoster")
  reversedStockAdjustments          StockAdjustment[]             @relation("StockAdjustmentReverser")
  createdProjectTemplates           ProjectTemplate[]             @relation("ProjectTemplateCreator")
  updatedProjectTemplates           ProjectTemplate[]             @relation("ProjectTemplateUpdater")
  sponsoredProjects                 Project[]                     @relation("ProjectSponsor")
  managedProjects                   Project[]                     @relation("ProjectManager")
  createdProjects                   Project[]                     @relation("ProjectCreator")
  updatedProjects                   Project[]                     @relation("ProjectUpdater")
  archivedProjects                  Project[]                     @relation("ProjectArchiver")
  projectMemberships                ProjectMember[]               @relation("ProjectMemberUser")
  addedProjectMembers               ProjectMember[]               @relation("ProjectMemberAdder")
  removedProjectMembers             ProjectMember[]               @relation("ProjectMemberRemover")
  projectActivityEvents             ProjectActivityEvent[]        @relation("ProjectActivityActor")
  ownedProjectTasks                 ProjectTask[]                 @relation("ProjectTaskOwner")
  completedProjectTasks             ProjectTask[]                 @relation("ProjectTaskCompleter")
  blockedProjectTasks               ProjectTask[]                 @relation("ProjectTaskBlocker")
  cancelledProjectTasks             ProjectTask[]                 @relation("ProjectTaskCanceller")
  reopenedProjectTasks              ProjectTask[]                 @relation("ProjectTaskReopener")
  createdProjectTasks               ProjectTask[]                 @relation("ProjectTaskCreator")
  updatedProjectTasks               ProjectTask[]                 @relation("ProjectTaskUpdater")
  projectTaskAssignments            ProjectTaskAssignee[]         @relation("ProjectTaskAssigneeUser")
  assignedProjectTasks              ProjectTaskAssignee[]         @relation("ProjectTaskAssigner")
  removedProjectTaskAssignments     ProjectTaskAssignee[]         @relation("ProjectTaskAssignmentRemover")
  completedProjectChecklistItems    ProjectTaskChecklistItem[]    @relation("ProjectChecklistCompleter")
  createdProjectChecklistItems      ProjectTaskChecklistItem[]    @relation("ProjectChecklistCreator")
  updatedProjectChecklistItems      ProjectTaskChecklistItem[]    @relation("ProjectChecklistUpdater")
  authoredProjectComments           ProjectComment[]              @relation("ProjectCommentAuthor")
  editedProjectComments             ProjectComment[]              @relation("ProjectCommentEditor")
  archivedProjectComments           ProjectComment[]              @relation("ProjectCommentArchiver")
  ownedProjectBlockers              ProjectBlocker[]              @relation("ProjectBlockerOwner")
  reportedProjectBlockers           ProjectBlocker[]              @relation("ProjectBlockerReporter")
  resolvedProjectBlockers           ProjectBlocker[]              @relation("ProjectBlockerResolver")
  ownedProjectRisks                 ProjectRisk[]                 @relation("ProjectRiskOwner")
  resolvedProjectRisks              ProjectRisk[]                 @relation("ProjectRiskResolver")
  createdProjectRisks               ProjectRisk[]                 @relation("ProjectRiskCreator")
  updatedProjectRisks               ProjectRisk[]                 @relation("ProjectRiskUpdater")
  ownedProjectMilestones            ProjectMilestone[]            @relation("ProjectMilestoneOwner")
  achievedProjectMilestones         ProjectMilestone[]            @relation("ProjectMilestoneAchiever")
  cancelledProjectMilestones        ProjectMilestone[]            @relation("ProjectMilestoneCanceller")
  createdProjectMilestones          ProjectMilestone[]            @relation("ProjectMilestoneCreator")
  updatedProjectMilestones          ProjectMilestone[]            @relation("ProjectMilestoneUpdater")
  createdProjectRecordLinks         ProjectRecordLink[]           @relation("ProjectRecordLinkCreator")
  updatedProjectRecordLinks         ProjectRecordLink[]           @relation("ProjectRecordLinkUpdater")
  archivedProjectRecordLinks        ProjectRecordLink[]           @relation("ProjectRecordLinkArchiver")
  createdProjectAttachments         ProjectAttachment[]           @relation("ProjectAttachmentCreator")
  archivedProjectAttachments        ProjectAttachment[]           @relation("ProjectAttachmentArchiver")
  notifications                     Notification[]
  auditEvents                       AuditEvent[]

  @@unique([tenantId, email])
}

model Role {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String?              @db.Uuid
  code        String
  name        String
  systemRole  Boolean              @default(false)
  status      RecordStatus         @default(ACTIVE)
  tenant      Tenant?              @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  assignments UserRoleAssignment[]

  @@unique([tenantId, code])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String?          @db.Uuid
  code        String           @unique
  module      String
  action      String
  description String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  roles       RolePermission[]
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserRoleAssignment {
  id       String       @id @default(uuid()) @db.Uuid
  userId   String       @db.Uuid
  roleId   String       @db.Uuid
  startsAt DateTime     @default(now())
  endsAt   DateTime?
  status   RecordStatus @default(ACTIVE)
  user     User         @relation(fields: [userId], references: [id])
  role     Role         @relation(fields: [roleId], references: [id])
}

model UserScopeAssignment {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  scopeType   ScopeType
  scopeId     String       @db.Uuid
  accessLevel AccessLevel
  startsAt    DateTime     @default(now())
  endsAt      DateTime?
  status      RecordStatus @default(ACTIVE)
  user        User         @relation(fields: [userId], references: [id])

  @@index([userId, scopeType, scopeId, status])
}

model ProjectTemplate {
  id                  String                @id @default(uuid()) @db.Uuid
  tenantId            String                @db.Uuid
  companyId           String                @db.Uuid
  code                String
  name                String
  projectType         String
  status              ProjectTemplateStatus @default(DRAFT)
  isRestrictedDefault Boolean               @default(false)
  configJson          Json
  createdByUserId     String                @db.Uuid
  updatedByUserId     String                @db.Uuid
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  company             Company               @relation(fields: [companyId], references: [id])
  createdBy           User                  @relation("ProjectTemplateCreator", fields: [createdByUserId], references: [id])
  updatedBy           User                  @relation("ProjectTemplateUpdater", fields: [updatedByUserId], references: [id])
  projects            Project[]

  @@unique([companyId, code])
  @@index([tenantId, companyId, status])
}

model Project {
  id                   String                 @id @default(uuid()) @db.Uuid
  tenantId             String                 @db.Uuid
  companyId            String                 @db.Uuid
  templateId           String?                @db.Uuid
  code                 String
  name                 String
  status               ProjectStatus          @default(DRAFT)
  projectType          String
  brandId              String?                @db.Uuid
  locationId           String?                @db.Uuid
  departmentId         String?                @db.Uuid
  costCenterId         String?                @db.Uuid
  sponsorUserId        String                 @db.Uuid
  managerUserId        String                 @db.Uuid
  isRestricted         Boolean                @default(false)
  startAt              DateTime?
  targetEndAt          DateTime?
  actualEndAt          DateTime?
  startDate            DateTime?              @db.Date
  targetEndDate        DateTime?              @db.Date
  actualEndDate        DateTime?              @db.Date
  description          String?
  templateSnapshotJson Json?
  projectConfigJson    Json?
  archivedAt           DateTime?
  archivedByUserId     String?                @db.Uuid
  archiveReason        String?
  version              Int                    @default(1)
  createdByUserId      String                 @db.Uuid
  updatedByUserId      String                 @db.Uuid
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  tenant               Tenant                 @relation(fields: [tenantId], references: [id])
  company              Company                @relation(fields: [companyId], references: [id])
  template             ProjectTemplate?       @relation(fields: [templateId], references: [id])
  brand                Brand?                 @relation(fields: [brandId, tenantId, companyId], references: [id, tenantId, companyId])
  location             Location?              @relation(fields: [locationId, tenantId, companyId], references: [id, tenantId, companyId])
  department           Department?            @relation(fields: [departmentId, tenantId, companyId], references: [id, tenantId, companyId])
  costCenter           CostCenter?            @relation(fields: [costCenterId, tenantId, companyId], references: [id, tenantId, companyId])
  sponsor              User                   @relation("ProjectSponsor", fields: [sponsorUserId], references: [id])
  manager              User                   @relation("ProjectManager", fields: [managerUserId], references: [id])
  archivedBy           User?                  @relation("ProjectArchiver", fields: [archivedByUserId], references: [id])
  createdBy            User                   @relation("ProjectCreator", fields: [createdByUserId], references: [id])
  updatedBy            User                   @relation("ProjectUpdater", fields: [updatedByUserId], references: [id])
  members              ProjectMember[]
  activityEvents       ProjectActivityEvent[]
  tasks                ProjectTask[]
  taskAssignees        ProjectTaskAssignee[]
  checklistItems       ProjectTaskChecklistItem[]
  comments             ProjectComment[]
  blockers             ProjectBlocker[]
  risks                ProjectRisk[]
  milestones           ProjectMilestone[]
  recordLinks          ProjectRecordLink[]
  attachments          ProjectAttachment[]

  @@unique([companyId, code])
  @@unique([id, tenantId, companyId])
  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, isRestricted])
  @@index([tenantId, companyId, brandId, status])
  @@index([tenantId, companyId, locationId, status])
  @@index([tenantId, companyId, departmentId, status])
  @@index([tenantId, companyId, costCenterId, status])
  @@index([managerUserId, status])
  @@index([sponsorUserId, status])
}

model ProjectMember {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @db.Uuid
  companyId       String            @db.Uuid
  projectId       String            @db.Uuid
  userId          String            @db.Uuid
  projectRole     ProjectMemberRole
  status          RecordStatus      @default(ACTIVE)
  addedByUserId   String            @db.Uuid
  removedAt       DateTime?
  removedByUserId String?           @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  company         Company           @relation(fields: [companyId], references: [id])
  project         Project           @relation(fields: [projectId], references: [id])
  user            User              @relation("ProjectMemberUser", fields: [userId], references: [id])
  addedBy         User              @relation("ProjectMemberAdder", fields: [addedByUserId], references: [id])
  removedBy       User?             @relation("ProjectMemberRemover", fields: [removedByUserId], references: [id])

  @@unique([projectId, userId])
  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, userId, status])
  @@index([projectId, projectRole, status])
}

model ProjectActivityEvent {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  companyId     String   @db.Uuid
  projectId     String   @db.Uuid
  actorUserId   String   @db.Uuid
  eventType     String
  entityType    String
  entityId      String   @db.Uuid
  occurredAt    DateTime @default(now())
  requestId     String?
  correlationId String?
  reason        String?
  beforeData    Json?
  afterData     Json?
  metadata      Json?
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])
  project       Project  @relation(fields: [projectId], references: [id])
  actor         User     @relation("ProjectActivityActor", fields: [actorUserId], references: [id])

  @@index([tenantId, companyId, projectId, occurredAt])
  @@index([tenantId, entityType, entityId, occurredAt])
  @@index([actorUserId, occurredAt])
}

model ProjectTask {
  id                     String                     @id @default(uuid()) @db.Uuid
  tenantId               String                     @db.Uuid
  companyId              String                     @db.Uuid
  projectId              String                     @db.Uuid
  taskKey                String
  title                  String
  description            String?
  status                 ProjectTaskStatus          @default(BACKLOG)
  priority               ProjectTaskPriority        @default(NORMAL)
  ownerUserId            String                     @db.Uuid
  startAt                DateTime?
  dueAt                  DateTime?
  startDate              DateTime?                  @db.Date
  dueDate                DateTime?                  @db.Date
  isBlocked              Boolean                    @default(false)
  blockedReason          String?
  blockedAt              DateTime?
  blockedByUserId        String?                    @db.Uuid
  completedAt            DateTime?
  completedByUserId      String?                    @db.Uuid
  completionNote         String?
  cancelledAt            DateTime?
  cancelledByUserId      String?                    @db.Uuid
  cancelReason           String?
  lastReopenedAt         DateTime?
  lastReopenedByUserId   String?                    @db.Uuid
  lastReopenReason       String?
