  proposedSnapshot                Json
  requestedAt                     DateTime      @default(now())
  approvedAt                      DateTime?
  rejectedAt                      DateTime?
  rejectionReason                 String?
  appliedAt                       DateTime?
  createdAt                       DateTime      @default(now())
