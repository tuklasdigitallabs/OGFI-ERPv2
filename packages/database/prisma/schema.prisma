  approvedBy                      User?         @relation("PurchaseOrderAmendmentApprover", fields: [approvedByUserId], references: [id])

  @@index([tenantId, companyId, status, requestedAt])
  @@index([purchaseOrderId, status])
  @@index([requestedByUserId])
  @@index([approvedByUserId])
}

model StockCountSession {
  id                  String            @id @default(uuid()) @db.Uuid
  tenantId            String            @db.Uuid
  companyId           String            @db.Uuid
  inventoryLocationId String            @db.Uuid
  publicReference     String
  countType           String
  scopeType           String            @default("ALL_ITEMS")
  status              String            @default("DRAFT")
  blindCount          Boolean           @default(true)
  freezeMovements     Boolean           @default(false)
  scheduledDate       DateTime?
  cutoffAt            DateTime?
  startedAt           DateTime?
  submittedAt         DateTime?
  reviewedAt          DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?
  reviewNotes         String?
  createdByUserId     String            @db.Uuid
  assignedToUserId    String?           @db.Uuid
  reviewedByUserId    String?           @db.Uuid
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  company             Company           @relation(fields: [companyId], references: [id])
  inventoryLocation   InventoryLocation @relation(fields: [inventoryLocationId], references: [id])
  createdBy           User              @relation("StockCountCreator", fields: [createdByUserId], references: [id])
  assignedTo          User?             @relation("StockCountAssignee", fields: [assignedToUserId], references: [id])
  reviewedBy          User?             @relation("StockCountReviewer", fields: [reviewedByUserId], references: [id])
  lines               StockCountLine[]
  stockAdjustments    StockAdjustment[]

  @@unique([companyId, publicReference])
  @@index([tenantId, companyId, status, scheduledDate])
  @@index([tenantId, companyId, inventoryLocationId, status])
}

model StockCountLine {
  id                      String                @id @default(uuid()) @db.Uuid
  stockCountSessionId     String                @db.Uuid
  tenantId                String                @db.Uuid
  companyId               String                @db.Uuid
  inventoryLocationId     String                @db.Uuid
  itemId                  String                @db.Uuid
  uomId                   String                @db.Uuid
  lineNumber              Int
  lotKey                  String                @default("NOLOT|NOEXP")
  lotNumber               String?
  expiryDate              DateTime?
  systemQuantityBaseUom   Decimal               @default(0) @db.Decimal(18, 6)
  countedQuantityBaseUom  Decimal?              @db.Decimal(18, 6)
  varianceQuantityBaseUom Decimal?              @db.Decimal(18, 6)
  notes                   String?
  countedByUserId         String?               @db.Uuid
  countedAt               DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  stockCountSession       StockCountSession     @relation(fields: [stockCountSessionId], references: [id])
  tenant                  Tenant                @relation(fields: [tenantId], references: [id])
  company                 Company               @relation(fields: [companyId], references: [id])
  inventoryLocation       InventoryLocation     @relation(fields: [inventoryLocationId], references: [id])
  item                    Item                  @relation(fields: [itemId], references: [id])
  uom                     Uom                   @relation(fields: [uomId], references: [id])
  countedBy               User?                 @relation("StockCountLineCounter", fields: [countedByUserId], references: [id])
  stockAdjustmentLines    StockAdjustmentLine[]

  @@unique([stockCountSessionId, itemId, lotKey])
  @@unique([stockCountSessionId, lineNumber])
  @@index([tenantId, companyId, stockCountSessionId, itemId])
  @@index([inventoryLocationId, itemId, lotKey])
}

model WastagePolicy {
  id                      String             @id @default(uuid()) @db.Uuid
  tenantId                String             @db.Uuid
  companyId               String             @db.Uuid
  name                    String
  policyVersion           String             @default("v1")
  priority                Int                @default(100)
  isActive                Boolean            @default(true)
  inventoryLocationId     String?            @db.Uuid
  wastageType             String?
  reasonCode              String?
  minimumEstimatedCost    Decimal?           @db.Decimal(18, 6)
  requiresEvidence        Boolean            @default(false)
  repeatLookbackDays      Int                @default(30)
  repeatItemLocationCount Int                @default(3)
  repeatReporterCount     Int                @default(5)
  notes                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tenant                  Tenant             @relation(fields: [tenantId], references: [id])
  company                 Company            @relation(fields: [companyId], references: [id])
  inventoryLocation       InventoryLocation? @relation(fields: [inventoryLocationId], references: [id])

  @@index([tenantId, companyId, isActive, priority])
  @@index([tenantId, companyId, inventoryLocationId, wastageType, reasonCode])
}

model OperationalReasonCode {
  id               String       @id @default(uuid()) @db.Uuid
  tenantId         String       @db.Uuid
  companyId        String       @db.Uuid
  workflow         String
  code             String
  label            String
