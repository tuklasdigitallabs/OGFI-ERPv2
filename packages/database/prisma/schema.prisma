model InventoryLocation {
  id                                String                  @id @default(uuid()) @db.Uuid
  tenantId                          String                  @db.Uuid
  companyId                         String                  @db.Uuid
  locationId                        String                  @db.Uuid
  code                              String
  name                              String
  storageType                       String?
  status                            RecordStatus            @default(ACTIVE)
  createdAt                         DateTime                @default(now())
  updatedAt                         DateTime                @updatedAt
  tenant                            Tenant                  @relation(fields: [tenantId], references: [id])
  company                           Company                 @relation(fields: [companyId], references: [id])
  location                          Location                @relation(fields: [locationId], references: [id])
  movements                         InventoryMovement[]
  relatedMovements                  InventoryMovement[]     @relation("InventoryMovementRelatedInventoryLocation")
  balances                          InventoryBalance[]
  goodsReceiptLines                 GoodsReceiptLine[]
  sourceInventoryTransferLines      InventoryTransferLine[] @relation("InventoryTransferLineSourceInventoryLocation")
  destinationInventoryTransferLines InventoryTransferLine[] @relation("InventoryTransferLineDestinationInventoryLocation")
  stockCountSessions                StockCountSession[]
  stockCountLines                   StockCountLine[]
  wastageReports                    WastageReport[]
  wastageLines                      WastageLine[]
  wastagePolicies                   WastagePolicy[]
  stockAdjustments                  StockAdjustment[]
  stockAdjustmentLines              StockAdjustmentLine[]

  @@unique([companyId, code])
  @@index([tenantId, companyId, locationId, status])
}

model PurchaseOrderBalanceClosure {
  id                              String        @id @default(uuid()) @db.Uuid
  tenantId                        String        @db.Uuid
  companyId                       String        @db.Uuid
  purchaseOrderId                 String        @db.Uuid
  requestedByUserId               String        @db.Uuid
  approvedByUserId                String?       @db.Uuid
  status                          String        @default("PENDING_APPROVAL")
  reason                          String
  supplierNoticeReference         String?
  supplierNoticeUnavailableReason String?
  notes                           String?
  lineSnapshot                    Json
  totalClosedQuantity             Decimal       @default(0) @db.Decimal(18, 6)
  totalClosedValue                Decimal       @default(0) @db.Decimal(18, 6)
  requestedAt                     DateTime      @default(now())
  approvedAt                      DateTime?
  rejectedAt                      DateTime?
  rejectionReason                 String?
  createdAt                       DateTime      @default(now())
  updatedAt                       DateTime      @updatedAt
  tenant                          Tenant        @relation(fields: [tenantId], references: [id])
  company                         Company       @relation(fields: [companyId], references: [id])
  purchaseOrder                   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  requestedBy                     User          @relation("PurchaseOrderBalanceClosureRequester", fields: [requestedByUserId], references: [id])
  approvedBy                      User?         @relation("PurchaseOrderBalanceClosureApprover", fields: [approvedByUserId], references: [id])

  @@index([tenantId, companyId, status, requestedAt])
  @@index([purchaseOrderId, status])
  @@index([requestedByUserId])
  @@index([approvedByUserId])
}

model PurchaseOrderAmendment {
  id                              String        @id @default(uuid()) @db.Uuid
  tenantId                        String        @db.Uuid
  companyId                       String        @db.Uuid
  purchaseOrderId                 String        @db.Uuid
  requestedByUserId               String        @db.Uuid
  approvedByUserId                String?       @db.Uuid
  status                          String        @default("PENDING_APPROVAL")
  reason                          String
