  purchaseRequestId String          @db.Uuid
  tenantId          String          @db.Uuid
  companyId         String          @db.Uuid
  authorUserId      String          @db.Uuid
  body              String
  createdAt         DateTime        @default(now())
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  company           Company         @relation(fields: [companyId], references: [id])
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  author            User            @relation(fields: [authorUserId], references: [id])

  @@index([tenantId, companyId, purchaseRequestId, createdAt])
}

model PurchaseRequestLine {
  id                 String                  @id @default(uuid()) @db.Uuid
  purchaseRequestId  String                  @db.Uuid
  itemId             String?                 @db.Uuid
  uomId              String?                 @db.Uuid
  lineNumber         Int
  description        String
  requestedQty       Decimal                 @db.Decimal(18, 6)
  uomCode            String
  purpose            String
  notes              String?
  purchaseRequest    PurchaseRequest         @relation(fields: [purchaseRequestId], references: [id])
  item               Item?                   @relation(fields: [itemId], references: [id])
  uom                Uom?                    @relation(fields: [uomId], references: [id])
  supplierQuoteLines SupplierQuotationLine[]
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([purchaseRequestId, lineNumber])
  @@index([itemId])
  @@index([uomId])
}

model QuotationRequest {
  id                String                    @id @default(uuid()) @db.Uuid
  tenantId          String                    @db.Uuid
  companyId         String                    @db.Uuid
  publicReference   String
  purchaseRequestId String                    @db.Uuid
  status            String                    @default("OPEN")
  requiredDate      DateTime
  createdByUserId   String                    @db.Uuid
  createdAt         DateTime                  @default(now())
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  company           Company                   @relation(fields: [companyId], references: [id])
  purchaseRequest   PurchaseRequest           @relation(fields: [purchaseRequestId], references: [id])
  createdBy         User                      @relation(fields: [createdByUserId], references: [id])
  supplierQuotes    SupplierQuotation[]
  recommendations   QuotationRecommendation[]
  purchaseOrders    PurchaseOrder[]

  @@unique([companyId, publicReference])
  @@unique([purchaseRequestId])
  @@unique([id, tenantId, companyId])
  @@index([tenantId, companyId, status])
}

model SupplierQuotation {
  id                 String                    @id @default(uuid()) @db.Uuid
  quotationRequestId String                    @db.Uuid
  tenantId           String                    @db.Uuid
  companyId          String                    @db.Uuid
  supplierId         String                    @db.Uuid
  quoteReference     String
  quoteDate          DateTime
  currencyCode       String
  totalAmount        Decimal                   @db.Decimal(18, 6)
  validityDate       DateTime?
  terms              String?
  status             String                    @default("RECORDED")
  createdAt          DateTime                  @default(now())
  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  company            Company                   @relation(fields: [companyId], references: [id])
  quotationRequest   QuotationRequest          @relation(fields: [quotationRequestId], references: [id])
  supplier           Supplier                  @relation(fields: [supplierId], references: [id])
  lines              SupplierQuotationLine[]
  recommendations    QuotationRecommendation[]
  purchaseOrders     PurchaseOrder[]

  @@unique([id, quotationRequestId])
  @@index([tenantId, companyId, supplierId])
  @@index([quotationRequestId])
}

model QuotationRecommendation {
  id                          String            @id @default(uuid()) @db.Uuid
  tenantId                    String            @db.Uuid
  companyId                   String            @db.Uuid
  quotationRequestId          String            @db.Uuid
  selectedSupplierQuotationId String            @db.Uuid
  preparedByUserId            String            @db.Uuid
  status                      String            @default("DRAFT")
  currencyCode                String
  selectedEvaluatedTotal      Decimal           @db.Decimal(18, 6)
  lowestEvaluatedTotal        Decimal           @db.Decimal(18, 6)
  quoteCount                  Int
  isLowestEvaluatedCost       Boolean
  selectionReason             String
  nonLowestJustification      String?
  singleSourceJustification   String?
  evaluationSnapshot          Json
  version                     Int               @default(1)
  submittedAt                 DateTime?
  approvedAt                  DateTime?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  tenant                      Tenant            @relation(fields: [tenantId], references: [id])
  company                     Company           @relation(fields: [companyId], references: [id])
  quotationRequest            QuotationRequest  @relation(fields: [quotationRequestId, tenantId, companyId], references: [id, tenantId, companyId])
  selectedSupplierQuotation   SupplierQuotation @relation(fields: [selectedSupplierQuotationId, quotationRequestId], references: [id, quotationRequestId])
  preparedBy                  User              @relation(fields: [preparedByUserId], references: [id])
  purchaseOrder               PurchaseOrder?

  @@unique([quotationRequestId, version])
  @@index([tenantId, companyId, status])
  @@index([quotationRequestId, status])
  @@index([selectedSupplierQuotationId])
}

model SupplierQuotationLine {
  id                  String               @id @default(uuid()) @db.Uuid
  supplierQuotationId String               @db.Uuid
  sourcePrLineId      String?              @db.Uuid
  itemId              String?              @db.Uuid
  quantity            Decimal              @db.Decimal(18, 6)
  uomId               String               @db.Uuid
  unitPrice           Decimal              @db.Decimal(18, 6)
  lineTotal           Decimal              @db.Decimal(18, 6)
  availabilityStatus  String
  leadTimeDays        Int?
  notes               String?
  supplierQuotation   SupplierQuotation    @relation(fields: [supplierQuotationId], references: [id])
  sourcePrLine        PurchaseRequestLine? @relation(fields: [sourcePrLineId], references: [id])
  item                Item?                @relation(fields: [itemId], references: [id])
  uom                 Uom                  @relation(fields: [uomId], references: [id])
  purchaseOrderLines  PurchaseOrderLine[]

  @@index([supplierQuotationId])
  @@index([sourcePrLineId])
}

model PurchaseOrder {
  id                          String                        @id @default(uuid()) @db.Uuid
  tenantId                    String                        @db.Uuid
  companyId                   String                        @db.Uuid
  brandId                     String?                       @db.Uuid
  publicReference             String
  purchaseRequestId           String                        @db.Uuid
  quotationRequestId          String                        @db.Uuid
  quotationRecommendationId   String                        @unique @db.Uuid
  selectedSupplierQuotationId String                        @db.Uuid
  supplierId                  String                        @db.Uuid
  deliveryLocationId          String                        @db.Uuid
  departmentId                String?                       @db.Uuid
  costCenterId                String?                       @db.Uuid
  currencyCode                String
  subtotalAmount              Decimal                       @default(0) @db.Decimal(18, 6)
  taxAmount                   Decimal                       @default(0) @db.Decimal(18, 6)
  discountAmount              Decimal                       @default(0) @db.Decimal(18, 6)
  totalAmount                 Decimal                       @db.Decimal(18, 6)
  expectedDeliveryDate        DateTime
  status                      String                        @default("DRAFT")
  sourceSnapshot              Json
  createdByUserId             String                        @db.Uuid
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  tenant                      Tenant                        @relation(fields: [tenantId], references: [id])
  company                     Company                       @relation(fields: [companyId], references: [id])
  brand                       Brand?                        @relation(fields: [brandId], references: [id])
  purchaseRequest             PurchaseRequest               @relation(fields: [purchaseRequestId], references: [id])
  quotationRequest            QuotationRequest              @relation(fields: [quotationRequestId, tenantId, companyId], references: [id, tenantId, companyId])
  quotationRecommendation     QuotationRecommendation       @relation(fields: [quotationRecommendationId], references: [id])
  selectedSupplierQuotation   SupplierQuotation             @relation(fields: [selectedSupplierQuotationId, quotationRequestId], references: [id, quotationRequestId])
  supplier                    Supplier                      @relation(fields: [supplierId], references: [id])
  deliveryLocation            Location                      @relation("PurchaseOrderDeliveryLocation", fields: [deliveryLocationId], references: [id])
  department                  Department?                   @relation(fields: [departmentId], references: [id])
  costCenter                  CostCenter?                   @relation(fields: [costCenterId], references: [id])
  createdBy                   User                          @relation(fields: [createdByUserId], references: [id])
  lines                       PurchaseOrderLine[]
  goodsReceipts               GoodsReceipt[]
  amendments                  PurchaseOrderAmendment[]
  balanceClosures             PurchaseOrderBalanceClosure[]

  @@unique([companyId, publicReference])
  @@index([tenantId, companyId, status])
  @@index([tenantId, deliveryLocationId, status])
  @@index([purchaseRequestId])
  @@index([quotationRequestId])
  @@index([selectedSupplierQuotationId])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id                        String                 @id @default(uuid()) @db.Uuid
  purchaseOrderId           String                 @db.Uuid
  tenantId                  String                 @db.Uuid
  companyId                 String                 @db.Uuid
  sourcePrLineId            String?                @db.Uuid
  sourceSupplierQuoteLineId String?                @db.Uuid
  itemId                    String?                @db.Uuid
  uomId                     String                 @db.Uuid
  lineNumber                Int
  description               String
  orderedQty                Decimal                @db.Decimal(18, 6)
  receivedQty               Decimal                @default(0) @db.Decimal(18, 6)
  cancelledQty              Decimal                @default(0) @db.Decimal(18, 6)
  unitPrice                 Decimal                @db.Decimal(18, 6)
  taxAmount                 Decimal                @default(0) @db.Decimal(18, 6)
  discountAmount            Decimal                @default(0) @db.Decimal(18, 6)
  lineTotal                 Decimal                @db.Decimal(18, 6)
  availabilityStatus        String?
  leadTimeDays              Int?
  notes                     String?
  purchaseOrder             PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id])
  tenant                    Tenant                 @relation(fields: [tenantId], references: [id])
  company                   Company                @relation(fields: [companyId], references: [id])
  sourcePrLine              PurchaseRequestLine?   @relation(fields: [sourcePrLineId], references: [id])
  sourceSupplierQuoteLine   SupplierQuotationLine? @relation(fields: [sourceSupplierQuoteLineId], references: [id])
  item                      Item?                  @relation(fields: [itemId], references: [id])
  uom                       Uom                    @relation(fields: [uomId], references: [id])
  goodsReceiptLines         GoodsReceiptLine[]

  @@unique([purchaseOrderId, lineNumber])
  @@index([tenantId, companyId])
  @@index([sourcePrLineId])
  @@index([sourceSupplierQuoteLineId])
  @@index([itemId])
