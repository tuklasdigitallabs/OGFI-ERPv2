# OGFI ERP staging environment - placeholder values only
COMPOSE_PROJECT_NAME=ogfi-erp-staging
APP_ENV=staging
NODE_VERSION=22
APP_URL=https://staging-erp.example.com
APP_DEFAULT_TIMEZONE=Asia/Manila
LOG_LEVEL=info

# PostgreSQL - application runtime credential only. Never add DIRECT_DATABASE_URL
# or an owner/migrator credential to this application environment file.
DATABASE_URL=postgresql://ogfi_stg_runtime:replace-me@staging-db.internal:5432/ogfi_erp_staging?schema=public

# Redis - future approved worker/queue scope only
# REDIS_URL=

# Auth and encryption - unique staging secrets
AUTH_MODE=local
AUTH_TRUSTED_PROXY_MODE=caddy_single_hop
AUTH_SECRET=replace-with-staging-secret
AUTH_THROTTLE_HMAC_KEY=replace-with-distinct-staging-throttle-hmac-key
AUTH_THROTTLE_KEY_VERSION=1
# AUTH_THROTTLE_PREVIOUS_HMAC_KEY=
# AUTH_THROTTLE_PREVIOUS_KEY_VERSION=
AUTH_THROTTLE_WINDOW_MINUTES=15
AUTH_THROTTLE_RETENTION_DAYS=30
AUTH_THROTTLE_IDENTIFIER_SHARDS=64
AUTH_THROTTLE_SOURCE_SHARDS=64
AUTH_ARGON2_MAX_CONCURRENCY=2
APPROVAL_ROUTING_V1_ENABLED=false
AUTH_HEALTH_METRICS_TOKEN=replace-with-distinct-staging-health-token-32-bytes
CADDY_METRICS_URL=http://caddy:2020/metrics
AUTH_RUNTIME_METRICS_URL=http://127.0.0.1:2021/api/internal/authentication-metrics
AUTH_THROTTLE_HEALTH_GRACE_MINUTES=10
# Candidate thresholds only. Calibrate and approve them from staging load evidence.
AUTH_THROTTLE_HEALTH_DENIED_THRESHOLD=100
AUTH_THROTTLE_HEALTH_PRESSURE_PERMILLE=900
AUTH_THROTTLE_HEALTH_ARGON2_REJECTED_THRESHOLD=10
AUTH_THROTTLE_HEALTH_ARGON2_DURATION_MS=5000
AUTH_THROTTLE_HEALTH_CADDY_REJECTED_THRESHOLD=100
APP_ENCRYPTION_KEY=replace-with-staging-32-byte-base64-key
APP_ENCRYPTION_KEY_VERSION=1
AUTH_SESSION_IDLE_MINUTES=30
AUTH_SESSION_ABSOLUTE_HOURS=12
AUTH_MFA_STEP_UP_MINUTES=15
AUTH_MFA_CHALLENGE_MINUTES=10
AUTH_MFA_CHALLENGE_LIMIT=5

# Demo / smoke users - use staging-only accounts
DEMO_USER_EMAIL=staging-user@example.test
DEMO_APPROVER_EMAIL=staging-approver@example.test
DEMO_ADMIN_EMAIL=staging-admin@example.test
DEMO_COMPANY_NAME=Configured Company
DEMO_BRAND_NAME=Configured Brand
DEMO_LOCATION_NAME=Configured Location

# Controlled evidence — isolated staging broker/volume/keys on the VPS.
EVIDENCE_STORAGE_PROVIDER=hostinger-local
EVIDENCE_BROKER_URL=http://evidence-broker:3010
EVIDENCE_BROKER_SHARED_SECRET_FILE=/run/secrets/evidence_broker_shared_secret
EVIDENCE_SCAN_RECONCILIATION_ENABLED=true
EVIDENCE_SCAN_RECONCILIATION_BATCH_SIZE=25
EVIDENCE_SCAN_RECONCILIATION_INTERVAL_SECONDS=60
EVIDENCE_SCAN_RECONCILIATION_LEASE_SECONDS=45
EVIDENCE_SCAN_RECONCILIATION_MAX_ATTEMPTS=10
EVIDENCE_SCAN_PENDING_TIMEOUT_MINUTES=60
EVIDENCE_SCAN_SIGNATURE_MAX_AGE_HOURS=24
EVIDENCE_UPLOAD_INTENT_TTL_SECONDS=300
EVIDENCE_UPLOAD_INTENT_ABSOLUTE_TTL_SECONDS=900
EVIDENCE_UPLOAD_LEASE_SECONDS=180
EVIDENCE_MAX_ACTIVE_UPLOAD_INTENTS_PER_USER=20
EVIDENCE_MAX_ACTIVE_UPLOAD_INTENTS_PER_COMPANY=500
EVIDENCE_MAX_UPLOAD_INTENTS_PER_USER_HOUR=100
EVIDENCE_MAX_UPLOAD_INTENTS_PER_COMPANY_HOUR=2000
EVIDENCE_MAX_UPLOAD_BYTES=26214400
EVIDENCE_DEFAULT_COMPANY_QUOTA_BYTES=
EVIDENCE_READINESS_LIVE_CHECK=true
EVIDENCE_BROKER_REQUEST_TIMEOUT_MS=10000
EVIDENCE_BROKER_MINIMUM_FREE_BYTES=
EVIDENCE_BROKER_MINIMUM_FREE_PERCENT=
EVIDENCE_BROKER_MINIMUM_FREE_INODE_PERCENT=
EVIDENCE_BROKER_CLAMD_TIMEOUT_MS=60000
EVIDENCE_BROKER_MAXIMUM_SIGNATURE_AGE_SECONDS=86400

EVIDENCE_HOST_STORAGE_ROOT=/srv/ogfi/evidence/staging
OGFI_PRODUCTION_ENV_FILE=/srv/ogfi/config/staging.env
# The root-owned database migration contract is stored separately at
# /etc/ogfi/database/role-contract.env; see infra/systemd/database/README.md.
OGFI_WEB_IMAGE=replace-with-reviewed-ogfi-image-digest
CLAMAV_IMAGE=replace-with-reviewed-clamav-image-digest
CADDY_BUILDER_IMAGE=docker.io/library/caddy:2.11.4-builder-alpine@sha256:8e89605351333ad2cc2f3bcc95275a2ccc427f88914050e86a5fde0fd77a63c4
CADDY_RUNTIME_IMAGE=docker.io/library/caddy:2.11.4-alpine@sha256:5f5c8640aae01df9654968d946d8f1a56c497f1dd5c5cda4cf95ab7c14d58648
CADDY_IMAGE=replace-with-built-ogfi-caddy-image-at-sha256
CADDY_ROLLBACK_IMAGE=replace-with-previous-ogfi-caddy-image-at-sha256
EVIDENCE_BROKER_SHARED_SECRET_FILE_HOST=/srv/ogfi/secrets/staging-evidence-broker-shared-secret
EVIDENCE_BROKER_KEYS_FILE_HOST=/srv/ogfi/secrets/staging-evidence-broker-keyring.json
EVIDENCE_BROKER_RUNTIME_UID_GID=
CLAMAV_RUNTIME_UID_GID=
CLAMAV_SIGNATURES_CONTAINER_PATH=
CLAMAV_SIGNATURE_VOLUME_NAME=
CLAMAV_HEALTHCHECK_CMD=
WEB_MEMORY_LIMIT=
WEB_CPU_LIMIT=
WEB_PIDS_LIMIT=
EVIDENCE_BROKER_MEMORY_LIMIT=
EVIDENCE_BROKER_CPU_LIMIT=
EVIDENCE_BROKER_PIDS_LIMIT=
EVIDENCE_BROKER_TMPFS_SIZE=
CLAMAV_MEMORY_LIMIT=
CLAMAV_CPU_LIMIT=
CLAMAV_PIDS_LIMIT=
CLAMAV_TMPFS_SIZE=
CLAMAV_RUN_TMPFS_SIZE=
CADDY_RUNTIME_UID_GID=
CADDY_TMPFS_SIZE=
CADDY_MEMORY_LIMIT=
CADDY_CPU_LIMIT=
CADDY_PIDS_LIMIT=
CONTAINER_LOG_MAX_SIZE=
CONTAINER_LOG_MAX_FILES=

# Email - staging sender/sandbox only
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=staging-erp@example.com
SMTP_SECURITY=starttls

# Observability - staging project/DSN only
ERROR_MONITORING_DSN=

# Reverse proxy / deployment. These are staging candidates only and must be
# calibrated on the actual Hostinger VPS before production values are approved.
WEB_PORT=3000
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
OGFI_SITE_ADDRESS=staging-erp.example.com
MAX_REQUEST_BODY_SIZE=27MiB
CADDY_READ_HEADER_TIMEOUT=10s
CADDY_READ_BODY_TIMEOUT=5m
CADDY_WRITE_TIMEOUT=5m
CADDY_IDLE_TIMEOUT=2m
CADDY_UPSTREAM_DIAL_TIMEOUT=5s
CADDY_UPSTREAM_RESPONSE_HEADER_TIMEOUT=60s
CADDY_AUTH_RESPONSE_HEADER_TIMEOUT=30s
CADDY_AUTH_RATE_WINDOW=1m
CADDY_SIGN_IN_GLOBAL_EVENTS=120
CADDY_SIGN_IN_SOURCE_EVENTS=30
CADDY_ACTIVATE_GLOBAL_EVENTS=60
CADDY_ACTIVATE_SOURCE_EVENTS=12
CADDY_MFA_GLOBAL_EVENTS=240
CADDY_MFA_SOURCE_EVENTS=60
CADDY_PASSWORD_COARSE_INFLIGHT=8
CADDY_MFA_COARSE_INFLIGHT=16

# Backup / restore evidence helpers
BACKUP_DIR=backups/staging
# BACKUP_FILE=backups/staging/ogfi-erp-staging-example.dump
# RESTORE_DATABASE_URL=postgresql://restore-user:replace-me@restore-db.internal:5432/ogfi_erp_staging_restore?schema=public
# ALLOW_RESTORE_TO_PRODUCTION=no
