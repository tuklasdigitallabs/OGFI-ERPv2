# Environment identity - placeholder values only
APP_ENV=development
NODE_VERSION=22
APP_URL=http://localhost:3000
APP_DEFAULT_TIMEZONE=Asia/Manila
LOG_LEVEL=info

# PostgreSQL — local Docker defaults only; replace outside local development
DATABASE_URL=postgresql://ogfi:change-me@localhost:5432/ogfi_erp?schema=public
DIRECT_DATABASE_URL=postgresql://ogfi:change-me@localhost:5432/ogfi_erp?schema=public

# Redis — optional; only needed for a future approved worker/queue scope
# REDIS_URL=redis://localhost:6379

# Auth and encryption — generate unique secrets for every environment
AUTH_MODE=demo
AUTH_TRUSTED_PROXY_MODE=untrusted
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_THROTTLE_HMAC_KEY=replace-with-a-distinct-long-throttle-hmac-key
AUTH_THROTTLE_KEY_VERSION=1
AUTH_THROTTLE_WINDOW_MINUTES=15
AUTH_THROTTLE_RETENTION_DAYS=30
AUTH_THROTTLE_IDENTIFIER_SHARDS=64
AUTH_THROTTLE_SOURCE_SHARDS=64
AUTH_ARGON2_MAX_CONCURRENCY=2
APPROVAL_ROUTING_V1_ENABLED=false
# Local-only placeholder. Staging/production require a distinct >=32-byte secret.
AUTH_HEALTH_METRICS_TOKEN=replace-with-local-health-metrics-token-32-bytes
CADDY_METRICS_URL=http://caddy:2020/metrics
AUTH_RUNTIME_METRICS_URL=http://127.0.0.1:2021/api/internal/authentication-metrics
AUTH_THROTTLE_HEALTH_GRACE_MINUTES=10
AUTH_THROTTLE_HEALTH_DENIED_THRESHOLD=100
AUTH_THROTTLE_HEALTH_PRESSURE_PERMILLE=900
AUTH_THROTTLE_HEALTH_ARGON2_REJECTED_THRESHOLD=10
AUTH_THROTTLE_HEALTH_ARGON2_DURATION_MS=5000
AUTH_THROTTLE_HEALTH_CADDY_REJECTED_THRESHOLD=100
APP_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
APP_ENCRYPTION_KEY_VERSION=1
# APP_ENCRYPTION_PREVIOUS_KEY=replace-only-during-reviewed-key-rotation
# APP_ENCRYPTION_PREVIOUS_KEY_VERSION=0
AUTH_SESSION_IDLE_MINUTES=30
AUTH_SESSION_ABSOLUTE_HOURS=12
AUTH_MFA_STEP_UP_MINUTES=15
AUTH_MFA_CHALLENGE_MINUTES=10
AUTH_MFA_CHALLENGE_LIMIT=5
# AUTH_BOOTSTRAP_TENANT_CODE=
# AUTH_BOOTSTRAP_USER_EMAIL=
# AUTH_BOOTSTRAP_AUTHORIZATION_REFERENCE=
# AUTH_BOOTSTRAP_OUTPUT_FILE=
# AUTH_ENCRYPTION_ROTATION_BATCH_SIZE=100

# Local demo user/context placeholders. Replace with configured seed data.
DEMO_USER_EMAIL=user@example.test
DEMO_TENANT_LOGIN_CODE=ogfi
DEMO_APPROVER_EMAIL=approver@example.test
DEMO_ADMIN_EMAIL=admin@example.test
DEMO_COMPANY_NAME=Configured Company
DEMO_BRAND_NAME=Configured Brand
DEMO_LOCATION_NAME=Configured Location

# Controlled evidence storage — local development/UAT only
EVIDENCE_STORAGE_PROVIDER=local-private
EVIDENCE_LOCAL_STORAGE_ROOT=.local/evidence-private
EVIDENCE_LOCAL_SCAN_MODE=explicit-test-clean
EVIDENCE_UPLOAD_INTENT_TTL_SECONDS=300
EVIDENCE_UPLOAD_INTENT_ABSOLUTE_TTL_SECONDS=900
EVIDENCE_UPLOAD_LEASE_SECONDS=180
EVIDENCE_MAX_ACTIVE_UPLOAD_INTENTS_PER_USER=20
EVIDENCE_MAX_ACTIVE_UPLOAD_INTENTS_PER_COMPANY=500
EVIDENCE_MAX_UPLOAD_INTENTS_PER_USER_HOUR=100
EVIDENCE_MAX_UPLOAD_INTENTS_PER_COMPANY_HOUR=2000
EVIDENCE_MAX_UPLOAD_BYTES=26214400
EVIDENCE_DEFAULT_COMPANY_QUOTA_BYTES=1073741824
EVIDENCE_READINESS_LIVE_CHECK=false

# Email — leave unset until the provider is selected
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURITY=starttls

# Observability
ERROR_MONITORING_DSN=

# Local-only legacy MinIO tooling (not used by controlled evidence storage)
MINIO_IMAGE=replace-with-reviewed-minio-image
# Custom Caddy build inputs must be immutable name@sha256 references. The
# resulting image and pre-pulled rollback image are also deployed by digest.
CADDY_BUILDER_IMAGE=docker.io/library/caddy:2.11.4-builder-alpine@sha256:8e89605351333ad2cc2f3bcc95275a2ccc427f88914050e86a5fde0fd77a63c4
CADDY_RUNTIME_IMAGE=docker.io/library/caddy:2.11.4-alpine@sha256:5f5c8640aae01df9654968d946d8f1a56c497f1dd5c5cda4cf95ab7c14d58648
CADDY_IMAGE=replace-with-built-ogfi-caddy-image-at-sha256
CADDY_ROLLBACK_IMAGE=replace-with-previous-ogfi-caddy-image-at-sha256
MINIO_ROOT_USER=local-minio-admin
MINIO_ROOT_PASSWORD=replace-this-local-password
WEB_PORT=3000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
OGFI_SITE_ADDRESS=:8080
ACME_EMAIL=
MAX_REQUEST_BODY_SIZE=27MiB
CADDY_READ_HEADER_TIMEOUT=10s
CADDY_READ_BODY_TIMEOUT=5m
CADDY_WRITE_TIMEOUT=5m
CADDY_IDLE_TIMEOUT=2m
CADDY_UPSTREAM_DIAL_TIMEOUT=5s
CADDY_UPSTREAM_RESPONSE_HEADER_TIMEOUT=60s
CADDY_AUTH_RESPONSE_HEADER_TIMEOUT=30s
# Local/staging candidates only; production requires hosted calibration.
CADDY_AUTH_RATE_WINDOW=1m
CADDY_SIGN_IN_GLOBAL_EVENTS=120
CADDY_SIGN_IN_SOURCE_EVENTS=30
CADDY_ACTIVATE_GLOBAL_EVENTS=60
CADDY_ACTIVATE_SOURCE_EVENTS=12
CADDY_MFA_GLOBAL_EVENTS=240
CADDY_MFA_SOURCE_EVENTS=60
CADDY_PASSWORD_COARSE_INFLIGHT=8
CADDY_MFA_COARSE_INFLIGHT=16
CADDY_RUNTIME_UID_GID=1000:1000
CADDY_TMPFS_SIZE=16m
CADDY_MEMORY_LIMIT=256m
CADDY_CPU_LIMIT=0.50
CADDY_PIDS_LIMIT=128

# Backup / restore evidence helpers
BACKUP_DIR=backups
# BACKUP_FILE=backups/ogfi-erp-example.dump
# RESTORE_DATABASE_URL=postgresql://ogfi:change-me@localhost:5433/ogfi_erp_restore?schema=public
# ALLOW_RESTORE_TO_PRODUCTION=no
