{
  "name": "@ogfi/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "evidence-broker": "tsx src/server/evidenceBroker/main.ts",
    "evidence-scan-reconcile": "tsx src/server/jobs/evidenceScanReconcile.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude tests/accessControl.integration.test.ts --exclude \"tests/authorization*.integration.test.ts\" --exclude tests/evidenceAuthorization.integration.test.ts",
    "test:access-control": "node ../../scripts/run-disposable-postgres-tests.mjs access-control -- pnpm --dir apps/web test:access-control:execute",
    "test:access-control:execute": "vitest run tests/accessControl.integration.test.ts",
    "test:authorization-adapters": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-adapters -- pnpm --dir apps/web test:authorization-adapters:execute",
    "test:authorization-adapters:execute": "vitest run tests/authorizationAdapter.integration.test.ts",
    "test:authorization-admin-platform": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-admin-platform -- pnpm --dir apps/web test:authorization-admin-platform:execute",
    "test:authorization-admin-platform:execute": "vitest run tests/authorizationAdminPlatform.integration.test.ts tests/authorizationCoreAdminRolePermissionConcurrency.integration.test.ts",
    "test:authorization-finance": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-finance -- pnpm --dir apps/web test:authorization-finance:execute",
    "test:authorization-finance:execute": "vitest run tests/authorizationFinance.integration.test.ts",
    "test:authorization-procurement-inventory": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-procurement-inventory -- pnpm --dir apps/web test:authorization-procurement-inventory:execute",
    "test:authorization-procurement-inventory:execute": "vitest run tests/authorizationProcurementInventory.integration.test.ts tests/authorizationWastageCancellation.integration.test.ts tests/authorizationStockAdjustmentApprovalCancellationRace.integration.test.ts tests/authorizationReceivingSerializationDatabase.integration.test.ts",
    "test:authorization-projects-operations": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-projects-operations -- pnpm --dir apps/web test:authorization-projects-operations:execute",
    "test:authorization-projects-operations:execute": "vitest run tests/authorizationProjectsOperations.integration.test.ts",
    "test:authorization-routes": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-routes -- pnpm --dir apps/web test:authorization-routes:execute",
    "test:authorization-routes:execute": "vitest run tests/authorizationRoutes.integration.test.ts",
    "test:authorization-workforce": "node ../../scripts/run-disposable-postgres-tests.mjs authorization-workforce -- pnpm --dir apps/web test:authorization-workforce:execute",
    "test:authorization-workforce:execute": "vitest run tests/authorizationWorkforce.integration.test.ts",
    "test:evidence-authorization": "node ../../scripts/run-disposable-postgres-tests.mjs evidence-authorization -- pnpm --dir apps/web test:evidence-authorization:execute",
    "test:evidence-authorization:execute": "vitest run tests/evidenceAuthorization.integration.test.ts",
    "test:authorization-manifest": "vitest run tests/authorizationManifest.test.mjs",
    "test:auth-db": "node ../../scripts/run-disposable-postgres-tests.mjs authentication-database -- pnpm --dir apps/web test:auth-db:execute",
    "test:auth-db:execute": "vitest run tests/authenticationDatabase.integration.test.ts",
    "test:e2e": "node ../../scripts/run-disposable-postgres-tests.mjs e2e -- pnpm --dir apps/web test:e2e:execute",
    "test:e2e:execute": "playwright test"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@ogfi/database": "workspace:*",
    "@ogfi/ui": "workspace:*",
    "lucide-react": "^1.22.0",
    "next": "^15.1.3",
    "nodemailer": "^9.0.3",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
