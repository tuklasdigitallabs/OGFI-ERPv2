{
  "name": "@ogfi/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "evidence-broker": "tsx src/server/evidenceBroker/main.ts",
    "evidence-scan-reconcile": "tsx src/server/jobs/evidenceScanReconcile.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude tests/accessControl.integration.test.ts --exclude \"tests/authorization*.integration.test.ts\" --exclude tests/evidenceAuthorization.integration.test.ts",
    "test:access-control": "vitest run tests/accessControl.integration.test.ts",
    "test:authorization-adapters": "vitest run tests/authorizationAdapter.integration.test.ts",
    "test:authorization-admin-platform": "vitest run tests/authorizationAdminPlatform.integration.test.ts",
    "test:authorization-finance": "vitest run tests/authorizationFinance.integration.test.ts",
    "test:authorization-procurement-inventory": "vitest run tests/authorizationProcurementInventory.integration.test.ts",
    "test:authorization-projects-operations": "vitest run tests/authorizationProjectsOperations.integration.test.ts",
    "test:authorization-routes": "vitest run tests/authorizationRoutes.integration.test.ts",
    "test:authorization-workforce": "vitest run tests/authorizationWorkforce.integration.test.ts",
    "test:evidence-authorization": "vitest run tests/evidenceAuthorization.integration.test.ts",
    "test:authorization-manifest": "vitest run tests/authorizationManifest.test.mjs",
    "test:auth-db": "cross-env AUTH_DATABASE_INTEGRATION=yes vitest run tests/authenticationDatabase.integration.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@ogfi/database": "workspace:*",
    "@ogfi/ui": "workspace:*",
    "lucide-react": "^1.22.0",
    "next": "^15.1.3",
    "nodemailer": "^9.0.3",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
